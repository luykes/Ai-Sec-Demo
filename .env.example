# ── Deployment (required for Docker + Let's Encrypt) ─────────────────────────
# Your DuckDNS subdomain or real domain (e.g. yourname.duckdns.org)
DOMAIN=

# Email for Let's Encrypt notifications (expiry warnings etc.)
LE_EMAIL=

# ── Prompt Security ───────────────────────────────────────────────────────────
# Enter this via the web UI Config Panel at runtime, OR set it here for local dev
PROMPT_SECURITY_API_KEY=

# Prompt Security API endpoint (default: apsouth region)
PROMPT_SECURITY_API_URL=https://apsouth.prompt.security/api/protect

# ── AI Operations Copilot ──────────────────────────────────────────────────────
# Required for the copilot agent to call Claude
ANTHROPIC_API_KEY=
