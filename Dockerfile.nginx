# Build PromptAI React app (copilot components are bundled in)
FROM node:20-alpine AS build
WORKDIR /build
COPY web/package*.json ./
RUN npm ci
COPY web/ .
RUN npm run build

# nginx serves the built SPA + reverse proxies /api and /copilot/api
FROM nginx:alpine
RUN apk add --no-cache gettext
COPY --from=build /build/dist /usr/share/nginx/html
COPY nginx/app.conf.template /etc/nginx/templates/app.conf.template
EXPOSE 80 443
